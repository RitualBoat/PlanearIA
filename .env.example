EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_SECRET=replace_with_same_value_as_backend_API_SECRET
EXPO_PUBLIC_ALLOW_NATIVE_LOCALHOST=false

# Para celular fisico en la misma red Wi-Fi, usa la IP LAN de tu laptop:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Solo desarrollo local. Nunca pongas API keys privadas de IA en variables EXPO_PUBLIC_*.
