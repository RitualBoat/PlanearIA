# =============================================================================
# Dependencies
# =============================================================================
node_modules/

# Python virtual environment (local tooling only; never committed or scanned)
.venv/
venv/
__pycache__/
*.pyc

# =============================================================================
# Expo / React Native
# =============================================================================
.expo/
dist/
web-build/
expo-env.d.ts

# Generated native folders
/ios
/android

# Metro bundler
.metro-health-check*

# Native build artifacts
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
.env*.local
!.env.example
!backend/.env.example
*.pem
devops_config.json
.vercel/


# =============================================================================
# AI Agents / Coding Assistants / Skills
# =============================================================================
# GitHub Copilot skills
skills/
skills-lock.json
.agents/*
.codex/*
roadmap-context
stitch-results

# Exceptions: shared agent config MUST be versioned because it configures the SDD workflow and the
# single-source harness (change: single-source-agent-harness). The generic "skills/" and ".agents/*"
# patterns above also match these, so re-include the project-owned ones explicitly.
!.codex/config.toml
!.codex/skills/
!.codex/skills/**
!.claude/skills/
!.claude/skills/**

# Project-owned neutral harness source under .agents/ (single-source-agent-harness): instructions,
# rules, permissions and project skills (interview-me, mvvm) MUST be versioned.
!.agents/instructions/
!.agents/instructions/**
!.agents/rules/
!.agents/rules/**
!.agents/permissions.json
!.agents/skills/
!.agents/skills/**

# ...but "impeccable" stays local: 100+ third-party files, re-installable via
# `npx skills add pbakaus/impeccable`. Not vendored (bloat + repo policy). Its parity = documented reinstall.
.agents/skills/impeccable/
.claude/skills/impeccable
.impeccable.md

# Playwright MCP scratch output (page snapshots, traces)
.playwright-mcp/

# CodeGraph MCP local index (generated per machine; never commit the SQLite DB)
.codegraph/

# Local SQLite databases and sidecar files (device/export/debug only)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
.mcp.local.json
.mcp.local.*.json


# AI coding tools (agent config directories)
.adal/
.agent/
.augment/
# .claude/ is NOT ignored — it holds shared Claude Code config (CLAUDE.md, settings.json, rules/)
.claude/settings.local.json
CLAUDE.local.md
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
