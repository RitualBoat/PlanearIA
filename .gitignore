# =============================================================================
# AI Agents / Coding Assistants / Skills
# =============================================================================
# GitHub Copilot skills
skills/
skills-lock.json
.agents/*
.codex/*
roadmap-context
stitch-results

# Exceptions: shared agent workflows MUST be versioned because they configure the SDD workflow.
# The generic "skills/" pattern above also matches nested tool skill folders, so re-include the
# project-owned ones explicitly.
!.agents/skills/
!.agents/skills/**
!.codex/config.toml
!.codex/skills/
!.codex/skills/**
!.claude/skills/
!.claude/skills/**

# Playwright MCP scratch output (page snapshots, traces)
.playwright-mcp/

# CodeGraph MCP local index (generated per machine; never commit the SQLite DB)
.codegraph/

# Local SQLite databases and sidecar files (device/export/debug only)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
.mcp.local.json
.mcp.local.*.json


# AI coding tools (agent config directories)
.adal/
.agent/
.augment/
# .claude/ is NOT ignored — it holds shared Claude Code config (CLAUDE.md, settings.json, rules/)
.claude/settings.local.json
CLAUDE.local.md
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
