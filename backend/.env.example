# Variables de entorno para backend (Vercel/local)

# MongoDB Atlas M0/free tier o Mongo local si se decide mas adelante
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/planeariaDB?retryWrites=true&w=majority

# API key interna para proteger endpoints backend.
# Debe coincidir con EXPO_PUBLIC_API_SECRET en la app durante desarrollo.
API_SECRET=replace_with_secure_random_value

# JWT/Auth
JWT_SECRET=replace_with_secure_random_value
JWT_EXPIRES_IN=7d

# IA Gateway multi-provider. Configura al menos uno para IA real.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
GROQ_API_KEY=
GROQ_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TOGETHER_API_KEY=
TOGETHER_MODEL=
AI_GATEWAY_PROVIDERS=

# Limites IA
AI_MAX_REQUESTS_PER_ACTION=10
AI_LIMIT_WINDOW_MS=86400000
OPENAI_TIMEOUT_MS=20000

# Modo dev IA: solo para pruebas locales, con advertencia visible en UI.
AI_DEV_MODE=false
AI_DEV_MAX_REQUESTS_PER_ACTION=100
AI_DEV_TOKEN=dev-token-local-testing-only

# CORS/local
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
