  "permissionsByRole": {
    "dev": [
      "gestionar_usuarios",
      "cambiar_roles",
      "ver_todos_grupos",
      "gestionar_planeaciones",
      "gestionar_grupos",
      "gestionar_alumnos",
      "gestionar_calificaciones",
      "gestionar_entregables",
      "gestionar_recursos",
      "gestionar_asistencia",
      "ver_propios_datos"
    ],
    "admin": [
      "gestionar_usuarios",
      "cambiar_roles",
      "ver_todos_grupos",
      "gestionar_planeaciones",
      "gestionar_grupos",
      "gestionar_alumnos",
      "gestionar_calificaciones",
      "gestionar_entregables",
      "gestionar_recursos",
      "gestionar_asistencia",
      "ver_propios_datos"
    ],
    "supervisor": [
      "ver_todos_grupos",
      "gestionar_planeaciones",
      "gestionar_grupos",
      "gestionar_alumnos",
      "gestionar_calificaciones",
      "gestionar_entregables",
      "gestionar_recursos",
      "gestionar_asistencia",
      "ver_propios_datos"
    ],
    "docente": [
      "gestionar_planeaciones",
      "gestionar_grupos",
      "gestionar_alumnos",
      "gestionar_calificaciones",
      "gestionar_entregables",
      "gestionar_recursos",
      "gestionar_asistencia",
      "ver_propios_datos"
    ],
    "alumno": ["ver_propios_datos"],
    "usuario": ["ver_propios_datos"]
  },
  "token": {
    "type": "Bearer",
    "accessTokenExpiresInMinutesTarget": 15,
    "refreshTokenExpiresInDaysTarget": 14,
    "claims": [
      "sub",
      "userId",
      "email",
      "role",
      "rol",
      "sessionId",
      "jti",
      "permissionsVersion",
      "iat",
      "exp"
    ]
  },
  "guest": {
    "role": "usuario",
    "canonicalRole": "alumno",
    "localOnly": true
  },
  "dev": {
    "role": "dev",
    "requiresDevEnvironment": true,
    "assignableFromAdminUi": false,
    "remoteRoleAssignmentEnv": "ALLOW_DEV_ROLE_ASSIGNMENT"
  }
