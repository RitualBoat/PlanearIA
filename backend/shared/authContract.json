{
  "version": 1,
  "permissionsVersion": 1,
  "roles": {
    "canonical": ["dev", "admin", "docente", "alumno"],
    "legacy": ["supervisor", "usuario"],
    "aliases": {
      "supervisor": "docente",
      "usuario": "alumno"
    },
    "assignable": ["admin", "docente", "alumno", "supervisor", "usuario"],
    "labels": {
      "dev": "Desarrollador",
      "admin": "Administrador",
      "docente": "Docente",
      "alumno": "Alumno",
      "supervisor": "Supervisor",
      "usuario": "Usuario"
    }
  },
  "permissions": {
    "GESTIONAR_USUARIOS": "gestionar_usuarios",
    "CAMBIAR_ROLES": "cambiar_roles",
    "VER_TODOS_GRUPOS": "ver_todos_grupos",
