{
  "name": "planearia",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "build:android:prebuild": "expo prebuild --platform android --non-interactive",
    "build:android:debug:ci": "cd android && ./gradlew assembleDebug",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint -- --quiet && npm test -- --runInBand",
    "test": "jest",
    "test:classroom": "jest src/__tests__/classroom --runInBand",
    "test:planeaciones": "jest src/__tests__/planeaciones --runInBand",
    "test:sync": "jest src/__tests__/sync --runInBand",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\" \"types/**/*.{ts,json}\"",
    "backend:install": "npm --prefix backend install",
    "backend:dev": "npm --prefix backend start",
    "backend:dev:local": "node scripts/localBackendServer.mjs",
    "backend:health": "node scripts/checkBackendHealth.mjs",
    "backend:check": "node scripts/checkBackendApiStatic.mjs && node scripts/testBackendIsolation.mjs",
    "backend:isolation": "node scripts/testBackendIsolation.mjs",
    "backend:deploy": "npm --prefix backend run deploy"
  },
  "dependencies": {
    "@10play/tentap-editor": "^1.0.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.8",
    "@tiptap/extension-table": "^3.11.0",
    "@tiptap/extension-table-cell": "^3.11.0",
    "@tiptap/extension-table-header": "^3.11.0",
    "@tiptap/extension-table-row": "^3.11.0",
    "docx": "^9.6.1",
    "expo": "~54.0.34",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.0.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.2",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/context/referencias-opensource",
      "<rootDir>/context/planeaciones-ground-truth/referencias-opensource"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/context/referencias-opensource",
      "<rootDir>/context/planeaciones-ground-truth/referencias-opensource"
    ]
  },
  "private": true
}
