{
  "name": "governed-repository",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "allowScripts": {
    "@fission-ai/openspec@1.6.0": true
  },
  "scripts": {
    "constructor:bootstrap": "node .project-constructor/runtime/bin/project-constructor.mjs bootstrap --target .",
    "constructor:doctor": "node .project-constructor/runtime/bin/project-constructor.mjs doctor --target .",
    "constructor:doctor:json": "node .project-constructor/runtime/bin/project-constructor.mjs doctor --target . --json",
    "constructor:github-plan": "node .project-constructor/runtime/bin/project-constructor.mjs github-plan --target .",
    "constructor:github-plan:json": "node .project-constructor/runtime/bin/project-constructor.mjs github-plan --target . --json",
    "constructor:opsx:adapt": "node .project-constructor/runtime/bin/project-constructor.mjs opsx-adapt --target .",
    "constructor:opsx:check": "node .project-constructor/runtime/bin/project-constructor.mjs opsx-check --target .",
    "constructor:rollback": "node .project-constructor/runtime/bin/project-constructor.mjs rollback --target .",
    "constructor:sync": "node .project-constructor/runtime/bin/project-constructor.mjs sync --target .",
    "constructor:sync:check": "node .project-constructor/runtime/bin/project-constructor.mjs sync --target . --check",
    "sdd:ready:archive": "node .project-constructor/runtime/bin/project-constructor.mjs readiness-check --target . --phase archive",
    "sdd:ready:propose": "node .project-constructor/runtime/bin/project-constructor.mjs readiness-check --target . --phase propose",
    "openspec:init": "npm exec --yes=false -- openspec init --tools codex,claude,cursor,github-copilot,opencode",
    "openspec:status": "npm exec --yes=false -- openspec status --json",
    "openspec:update": "npm exec --yes=false -- openspec update",
    "openspec:validate": "npm exec --yes=false -- openspec validate --all --strict --no-interactive"
  },
  "devDependencies": {
    "@fission-ai/openspec": "1.6.0"
  }
}
